# Path for temporary installed components
## '/tmp' Recommended for easy cleanup
temp_path="/tmp/Catalina_Scripts_Assets"

# Path for homebrew installation
## Home Directory Recommended For persistant presence of homebrew programs [500MiB]
brew_path="/Users/$USER/"

## Installation method for openssl
### Mandatory for python install, python install will be skipped if openssl isn't installed
openssl_installation_method=brew        # Options: [brew, manual]
### Custom openssl path if "openssl_installation_method=manual"
openssl_path=

# Path for python installation
## Same as Homebrew, Home is Recommended
python_path="/Users/$USER/.local"

# Path for Applications
## Recommended to leave in goinfre, in a publicaly accessible folder for everyone
goinfre_apps_dir="/goinfre/Applications"
